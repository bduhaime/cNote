<!DOCTYPE html><!-- Copyright (C) 2017-2018, Brad Duhaime. All Rights Reserved. --><!-- #include file="includes/security.asp" --><!-- #include file="includes/dbug.asp" --><!-- #include file="includes/dataconnection.asp" --><!-- #include file="includes/userLog.asp" --><!-- #include file="includes/userPermitted.asp" --><!-- #include file="includes/dateValidationPattern.asp" --><!-- #include file="includes/systemControls.asp" --><!-- #include file="includes/customerTitle.asp" --><!-- #include file="includes/formatHTML5Date.asp" --><!-- #include file="includes/checkPageAccess.asp" --><!-- #include file="includes/jwt.all.asp" --><!-- #include file="includes/sessionJWT.asp" --><!-- #include file="includes/apiServer.asp" --><% call checkPageAccess(49)customerID = request.querystring("id")%><!-- #include file="includes/validateCustomerAccess.asp" --><%	templateFromIncompleteProj = systemControls("Allow template generation from incomplete projects")'===============================================================================function formatBrowserDateTime(inputDateTime)'===============================================================================		dbug("formatBrowserDateTime(" & inputDateTime & ")")			if not isNull(inputDateTime) then 		inputDateYYYY 	= cStr(datePart("yyyy",inputDateTime))		inputDateMM	 	= right("0" & cStr(datePart("m",inputDateTime)),2)		inputDateDD	 	= right("0" & cStr(datePart("d",inputDateTime)),2)		if (datePart("h",inputDateTime)) >= 12 then 			inputDateHH	 	= right("0" & cStr(datePart("h",inputDateTime)-12),2)			inputDateAP		= "PM"		else 			if datePart("h",inputDateTime) = 0 then 				inputDateHH = "12"			else 				inputDateHH	 	= right("0" & cStr(datePart("h",inputDateTime)),2)			end if			inputDateAP		= "AM"		end if		inputDateNN	 	= right("0" & cStr(datePart("n",inputDateTime)),2)				formatBrowserDateTime = inputDateYYYY 	& "-" &_										inputDateMM		& "-" &_										inputDateDD		& " " &_										inputDateHH		& ":" &_										inputDateNN		& " " &_										inputDateAP	else 		formatBrowserDateTime = ""	end if	end function'==============================================================================='***********************************************************************************'***********************************************************************************'***********************************************************************************dbug("before top-logic")if len(request.querystring("id")) > 0 then	dbug("'id' value present in querystring")		customerID = request.querystring("id")	title = customerTitle(customerID)	title = session("clientID") & " - <a href=""/customerList.asp?"">Customers</a><img src=""images/ic_chevron_right_white_18dp_2x.png"">" & title	end ifdbug("after top-logic")'***********************************************************************************'***********************************************************************************'***********************************************************************************'***********************************************************************************%><html><head>		<!-- #include file="includes/globalHead.asp" -->		<link rel="stylesheet" href="dialog-polyfill.css" /><!-- 	<script src="moment.min.js"></script> -->	<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>	<script src="https://cdnjs.cloudflare.com/ajax/libs/moment-timezone/0.5.33/moment-timezone-with-data.min.js"></script>		<script src="//cdn.datatables.net/plug-ins/1.10.21/sorting/datetime-moment.js"></script>		<script src="customerCalls.js"></script>	<script src="customerView.js"></script>	<script src="customerAnnotations.js"></script>			<script src="https://cdn.jsdelivr.net/npm/luxon@3.3.0/build/global/luxon.min.js"></script>	<script>		//================================================================================		function showTransientMessage( msg ) {		//================================================================================			let notification = document.querySelector('.mdl-js-snackbar');						notification.MaterialSnackbar.showSnackbar({ message: msg });					}		//================================================================================				//================================================================================		function populateCallTypeSelectmenu( callTypeID ) {		//================================================================================						return new Promise( async (resolve, reject) => {								$('#newCallType').find('option').remove().end();								$.ajax({					url: `${apiServer}/api/customerCallTypes`,					headers: { 'Authorization': 'Bearer ' + sessionJWT }				}).done( async function( data ) {										let options = [], selected = '';					options.push( `<option selected disabled>Make a selection...</option>` );					for ( row of data ) {						if ( !!callTypeID && callTypeID == row.id ) {							selected = 'selected';						} else {							selected = '';						}						options.push( `<option value="${ row.id }" ${selected}>${ row.name }</option>` )					}										await $( '#newCallType' ).empty();					await $( '#newCallType' ).append( options.join( '' ) );										await $( '#newCallType' ).selectmenu( 'refresh' );							resolve( true );	 				}).fail( function( err ) {					showTransientMessage( 'Error retrieving callTypes' );					reject( err );				});							});		}		//================================================================================				//================================================================================		function populateTimezoneSelectmenu( timezoneSelector, scheduledTimeZoneInd ) {		//================================================================================			return new Promise( async (resolve, reject) => {								$( timezoneSelector ).find('option').remove().end();				let defaultIanaName;								$.ajax({					url: `${apiServer}/api/timezones`,					data: { customerID: customerID, scheduledTimeZoneInd: scheduledTimeZoneInd },					headers: { 'Authorization': 'Bearer ' + sessionJWT }				}).done( function( data ) {										let options = [] 										options.push( `<option disabled selected></option>` );					for ( row of data ) {						let selected;						if ( row.default ) {							selected = 'selected';							defaultIanaName = row.ianaName;						} else {							selected = '';						}						// 						let selected = ( row.default ) ? 'selected' : ''; 						options.push( `<option value="${row.id}" ${selected}>${row.ianaName}</option>` )					}						$( timezoneSelector )						.append( options.join( '' ) )						.selectmenu( 'refresh' );												resolve( defaultIanaName );					}).fail( function( err ) {					showTransientMessage( 'Error retrieving time zones' );					reject( err );									});			});		}		//================================================================================				//================================================================================		function saveNewCall() {		//================================================================================			return new Promise( async (resolve, reject) => {// 				const startDate = $( '#newStartDate' ).val();												// value of startDate// 				const startTime = $( '#newStartTime' ).val();												// value of startTime// 				const startDateTime = `${startDate} ${startTime}`;											// combined values of startDate and startTime				const scheduledStartDateTime = $( '#scheduledStartDateTime' ).val();					// combined values of scheduledStartDate and scheduledStartTime				const startTZ = $( '#newTimezone' ).find( 'option:selected' ).text();				// name of selected time zone indicator				const namedOffset = moment.tz( scheduledStartDateTime, startTZ )												.format( 'z' );																const payload = { 						customerID: $( '#customerID' ).val(),						callID: $( '#callID' ).val(),						callType: $( '#newCallType' ).val(),						scheduledStartDateTime: scheduledStartDateTime,						timezone: $( '#newTimezone').val(),						scheduledTimeZoneInd: startTZ,						scheduledNamedOffset: namedOffset,						duration: $( '#newDuration' ).val(),						copyUtopias: $( '#newCopyUtopias' ).prop( 'checked' ),						copyKeyInitiatives: $( '#newCopyKeyInitiatives' ).prop( 'checked' ),						copyProjects: $( '#newCopyProjects' ).prop( 'checked' ),						actualStartDateTime: $( '#actualStartDateTime' ).val(),						actualEndDateTime: $( '#actualEndDateTime' ).val(),					}									$.ajax({										url: `${ apiServer }/api/customerCalls`,					type: 'POST',					async: false,					data: payload,					headers: { 'Authorization': 'Bearer ' + sessionJWT }					}).done( function( data ) {					resolve( data );				}).fail( function( err ) {					reject( err );				});			});		}		//================================================================================				const params = new Proxy(new URLSearchParams(window.location.search), {			get: (searchParams, prop) => searchParams.get(prop),		});				const customerID 	= params.id;		// this little script automatically refreshes this page is the user navigates here using browser's back arrow				if(!!window.performance && window.performance.navigation.type == 2) {			window.location.reload();		}				$(document).ready(function() {							$( document ).tooltip();						$( '#newCopyUtopias' ).checkboxradio();			$( '#newCopyKeyInitiatives' ).checkboxradio();			$( '#newCopyProjects' ).checkboxradio();						//-----------------------------------------------------------------------------------			$( "#confirmDelete" ).dialog({			//-----------------------------------------------------------------------------------				resizable: false,				autoOpen: false,				height: "auto",				width: 400,				modal: true,				buttons: {					Delete: function() {						const deleteCallID = $( '#deleteCallID' ).val();						$.ajax({							url: `${apiServer}/api/customerCalls/${deleteCallID}`,							headers: { 'Authorization': 'Bearer ' + sessionJWT },							type: 'delete'						}).done( function() {								showTransientMessage( 'Call deleted' );						}).fail( function() {								showTransientMessage( 'Error while deleting call' );						}).always( function() {							$( '#tbl_clientCalls' ).DataTable().ajax.reload();			 				$( '#deleteCallID' ).val( '' );							$( '#confirmDelete' ).dialog( "close" );						});											},					Cancel: function() {		 				$( '#deleteCallID' ).val( '' );						$( '#confirmDelete' ).dialog( "close" );					}				}			});			//-----------------------------------------------------------------------------------												//-----------------------------------------------------------------------------------			$( "#newCall" ).dialog({			//-----------------------------------------------------------------------------------				resizable: false,				autoOpen: false,				height: 'auto',				width: 700,				modal: true,				buttons: {					'Save': async function() {												try {																					if ( !$( '#newCallType' ).val() ) {								$( '#newCallType' ).parent().addClass( 'ui-state-error' );								alert( 'Customer Call Type is required' );								return false;							} else {								$( '#newCallType' ).parent().removeClass( 'ui-state-error' );							}																																			let newCallResult = await saveNewCall();							$( '#newCall' ).dialog( "close" );							$( '#tbl_clientCalls' ).DataTable().ajax.reload();							showTransientMessage( 'Call saved' );						} catch( err ) {							console.error( err );							showTransientMessage( 'Error saving call' );						}											},					'Save & Annotate': async function() {							if ( !$( '#newCallType' ).val() ) {								$( '#newCallType' ).parent().addClass( 'ui-state-error' );								alert( 'Customer Call Type is required' );								return false;							} else {								$( '#newCallType' ).parent().removeClass( 'ui-state-error' );							}																																		try {							showTransientMessage( 'Call saved' );							$( '#newCall' ).dialog( "close" );							let newCallID = await saveNewCall();							$( '#tbl_clientCalls' ).DataTable().ajax.reload();							location = `annotateCalls.asp?customerID=${customerID}&callID=${newCallID}`;						} catch( err ) {							console.error( err );							showTransientMessage( 'Error saving call' );						}					},					'Cancel': function () {						$('#newCopyUtopias')							.prop('checked',false)							.checkboxradio( 'disable' )							.checkboxradio('refresh')												$('#newCopyProjects')							.prop('checked',false)							.checkboxradio( 'disable' )							.checkboxradio('refresh')												$('#newCopyKeyInitiatives')							.prop('checked',false)							.checkboxradio( 'disable' )							.checkboxradio('refresh')												$( '#newCall' ).dialog( "close" );					},				},				open: async function() {										const newCall 						= $( this ).data().newCall;					const callID						= $( this ).data().callID;					const callTypeID 					= $( this ).data().callTypeID;					const scheduledStartDate 		= $( this ).data().scheduledStartDate;					const scheduledStartTime 		= $( this ).data().scheduledStartTime;					const scheduledTimeZoneInd 	= $( this ).data().scheduledTimeZoneInd;					const scheduledDuration 		= $( this ).data().scheduledDuration;					const scheduledStartDateTime	= scheduledStartDate + 'T' + scheduledStartTime;					const actualStartDate			= $( this ).data().actualStartDate;					const actualStartTime			= $( this ).data().actualStartTime;					const actualEndDate				= $( this ).data().actualEndDate;					const actualEndTime				= $( this ).data().actualEndTime;					const actualStartDateTime		= actualStartDate + 'T' + actualStartTime;					const actualEndDateTime			= actualEndDate + 'T' + actualEndTime;									$( '#customerID' ).val( params.id );					await populateCallTypeSelectmenu( callTypeID );										let defaultTZ, defaultTzDateTime, localDateTime;					const localTZ = moment.tz.guess();																		// guess the current timezone					if ( newCall ) {						$( 'div.initialNotes' ).show();						$( 'div.actual' ).hide();						$( '#callID' ).val( '' );						defaultTZ = await populateTimezoneSelectmenu( '#newTimezone', null );						localDateTime = moment();																				// current local date/time						const minTillNextQuarterHour = 15 - ( localDateTime.minutes() % 15 );					//	minutes until the next 1/4-hour						const nextQuarterHour = localDateTime.add( minTillNextQuarterHour, 'minutes' );		// the next 1/4-hour						defaultTzDateTime = moment.tz( nextQuarterHour, defaultTZ );								// converted to default timezone											} else {												$( 'div.initialNotes' ).hide();						$( 'div.actual' ).show();						$( '#callID' ).val( callID );												await populateTimezoneSelectmenu( '#newTimezone', scheduledTimeZoneInd );						await populateTimezoneSelectmenu( '#actualTimezone', scheduledTimeZoneInd );												if ( !!actualStartDateTime ) {							$( '#actualStartDateTime' ).val( moment( actualStartDateTime ).format( 'YYYY-MM-DDTHH:mm' ) );							$( '#actualEndDateTime' ).prop('min', actualStartDateTime );						}						if ( !!actualEndDateTime ) {							$( '#actualEndDateTime' ).val( actualEndDateTime );							$( '#actualStartDateTime' ).prop('max', actualEndDateTime );						}																															defaultTzDateTime = moment( scheduledStartDate + ' ' + scheduledStartTime, 'MM/DD/YYYY hh:mm A' );												if ( actualStartDate && actualStartTime && actualEndDate && actualEndTime ){							const actualStartDateTime = moment( actualStartDate + ' ' + actualStartTime, 'YYYY-MM-DD HH:mm' );							const actualEndDateTime = moment( actualEndDate + ' ' + actualEndTime, 'YYYY-MM-DD HH:mm' );														const actualDiff = actualEndDateTime.diff( actualStartDateTime );														if ( !!actualDiff ) {								$( '#actualDuration' ).val( moment.duration( actualDiff ).as( 'minutes' ) + ' minutes' );							} else {								$( '#actualDuration' ).val( '' );							}						} else {							$( '#actualDuration' ).val( '' );						}											}					$( '#scheduledStartDateTime' ).val( defaultTzDateTime.format( 'YYYY-MM-DDTHH:mm' ) );					$( '#localTimezone' ).val( localTZ );					adjustLocalStartDateTime();				},				close: function() {					$( '#newCallType' ).parent().removeClass( 'ui-state-error' );				},											});			//-----------------------------------------------------------------------------------									//-----------------------------------------------------------------------------------			function adjustLocalStartDateTime() {			//-----------------------------------------------------------------------------------								const scheduledStartDateTime = $( '#scheduledStartDateTime' ).val();											// combined values of startDate and startTime				const startTZ = $( '#newTimezone' ).find( 'option:selected' ).text();				const localTimezone = $( '#localTimezone' ).val();				const localStartDateTime = moment.tz( scheduledStartDateTime, startTZ )												.tz( localTimezone )												.format( 'YYYY-MM-DDTHH:mm' );				$( '#localStartDateTime' ).val( localStartDateTime );				return true;							}			//-----------------------------------------------------------------------------------			//-----------------------------------------------------------------------------------			$( '#newCallType' ).selectmenu({			//-----------------------------------------------------------------------------------				width: 500,				change: function( event, ui ) {					const callTypeID = $( this ).val();									$.ajax({						url: `${ apiServer }/api/customerCallNoteTypes`,						data: { callTypeID: callTypeID },						headers: { 'Authorization': 'Bearer ' + sessionJWT }					}).done( function( data ) {																		if ( data.utopiaInd ) {							$( '#newCopyUtopias' ).checkboxradio( 'enable' );						} else {							$( '#newCopyUtopias' ).checkboxradio( 'disable' );						}												if ( data.projectInd ) {							$( '#newCopyProjects' ).checkboxradio( 'enable' );						} else {							$( '#newCopyProjects' ).checkboxradio( 'disable' );						}												if ( data.keyInitiativeInd ) {							$( '#newCopyKeyInitiatives' ).checkboxradio( 'enable' );						} else {							$( '#newCopyKeyInitiatives' ).checkboxradio( 'disable' );						}											}).fail( function( err ) {												console.error( `Error occured on change of newCallType` );						console.error( err );											});				},				select: function( event, ui ) {					$( '#newDuration' ).selectmenu( 'refresh' );					$( '#newTimezone' ).selectmenu( 'refresh' );				}							});			//-----------------------------------------------------------------------------------						//-----------------------------------------------------------------------------------			$( '#newDuration' ).selectmenu({ 				width: 120,			});			//-----------------------------------------------------------------------------------									//-----------------------------------------------------------------------------------			$( '#newTimezone' ).selectmenu({ 			//-----------------------------------------------------------------------------------				width: 280,				select: function( event, ui ) {					adjustLocalStartDateTime();				}			 });			//-----------------------------------------------------------------------------------			//-----------------------------------------------------------------------------------			$( '#actualTimezone' ).selectmenu({			//-----------------------------------------------------------------------------------				width: 280,							});			//-----------------------------------------------------------------------------------									//-----------------------------------------------------------------------------------			var table = $('#tbl_clientCalls')	 			.on( 'click', 'tbody tr', function() { 					window.location.href = `annotateCalls.asp?customerID=${params.id}&callID=${this.id}`; 				}) 				.on( 'mouseover', 'tbody tr', function() { 					$( this ).find( 'span.actions' ).toggle(); 				}) 				.on( 'mouseout', 'tbody tr', function() { 					$( this ).find( 'span.actions' ).toggle(); 				}) 				.on( 'click', '.deleteButton', function(e) {	 				e.stopPropagation();	 					 				const deleteCallID = $( this ).closest( 'tr' ).attr( 'id' );	 				const name = $( this ).closest( 'tr' ).find( '.callTypeName' ).html();	 				const scheduledStart = $( this ).closest( 'tr' ).find( '.scheduledStartDateTime' ).html();	 					 				$( '#deleteCallID' ).val( deleteCallID );	 				$( "#confirmDelete" )	 					.dialog( 'option', 'title', `Delete the ${name} call scheduled for ${scheduledStart}?`)	 					.dialog( "open" ); 				}) 				.on( 'click', '.editButton', async function( e ) {	 					 				e.stopPropagation();	 				const selectedRow = $( this ).closest( 'tr' );	 				const rowData = $( '#tbl_clientCalls' ).DataTable().row( selectedRow ).data();	 					 				const callID 						= rowData[ 'callID' ];	 				const callTypeID 					= rowData[ 'callTypeID' ];	 				const callTypeName 				= rowData[ 'callTypeName' ];	 				const scheduledStartDate		= rowData[ 'scheduledStartDate' ];	 				const scheduledStartTime		= rowData[ 'scheduledStartTime' ];	 				const scheduledDuration 		= rowData[ 'scheduledDuration' ];	 				const scheduledTimezone 		= rowData[ 'scheduledTimezone' ];	 				const scheduledTimeZoneInd 	= rowData[ 'scheduledTimeZoneInd' ];	 				const actualStartDate 			= moment( rowData[ 'actualStartDateTime' ], 'MM/DD/YYYY HH:mm A' ).format( 'YYYY-MM-DD' );	 				const actualStartTime 			= moment( rowData[ 'actualStartDateTime' ], 'MM/DD/YYYY HH:mm A' ).format( 'HH:mm' );	 				const actualEndDate 				= moment( rowData[ 'actualEndDateTime' ], 'MM/DD/YYYY HH:mm A' ).format( 'YYYY-MM-DD' );	 				const actualEndTime				= moment( rowData[ 'actualEndDateTime' ], 'MM/DD/YYYY HH:mm A' ).format( 'HH:mm' );	 				await $( "#newCall" )	 					.dialog({ title: 'Edit Call' })	 					.data( 'newCall', false )	 					.data( 'callID', callID )	 					.data( 'callTypeID', callTypeID )	 					.data( 'scheduledStartDate', scheduledStartDate )	 					.data( 'scheduledStartTime', scheduledStartTime )	 					.data( 'scheduledTimeZoneInd', scheduledTimeZoneInd )	 					.data( 'scheduledDuration', scheduledDuration )	 					.data( 'actualStartDate', actualStartDate )	 					.data( 'actualStartTime', actualStartTime )	 					.data( 'actualEndDate', actualEndDate )	 					.data( 'actualEndTime', actualEndTime )	 					.dialog( "open" );	 				 				})				.DataTable({					ajax: {						url: `${apiServer}/api/customerCalls`,						data: { customerID: params.id },						headers: { 'Authorization': 'Bearer ' + sessionJWT },						dataSrc: ''					},					rowId: 'callID',					scrollY: 630,					scroller: true,					scrollCollapse: true,					columnDefs: [						{ targets: 'callName', data: 'callName', visible: false },						{ targets: 'callTypeID', data: 'callTypeID',	visible: false },						{ targets: 'callTypeName', data: 'callTypeName', className: 'callTypeName dt-body-left dt-head-left' },						{ targets: 'callLeadID', data: 'callLeadID', visible: false },						{ targets: 'callLeadName', data: 'callLeadName', className: 'dt-body-left dt-head-left' },						{ 							targets: 'scheduledStartDateTime', 								data: 'scheduledStartDateTime',								className: 'scheduledStartDateTime dt-body-center dt-head-center',							render: function ( data, type, row ) {								if ( type === 'sort' ) {									return moment( data, 'MM/DD/YYYY hh:mm A z' ).format( 'YYYY/MM/DD HH:mm:ss' );								}								return data;							}						},						{ targets: 'scheduledStartDate', data: 'scheduledStartDate', className: 'dt-body-center dt-head-center', visible: false },						{ targets: 'scheduledStartTime', data: 'scheduledStartTime', className: 'dt-body-center dt-head-center',	visible: false },						{ targets: 'scheduledEndDateTime', data: 'scheduledEndDateTime', className: 'end dt-body-center dt-head-center', 	visible: false },						{ targets: 'scheduledEndDate', data: 'scheduledEndDate', className: 'dt-body-center dt-head-center', visible: false },						{ targets: 'scheduledEndTime', data: 'scheduledEndTime', className: 'dt-body-center dt-head-center', visible: false },						{ targets: 'scheduledTimezone', data: 'scheduledTimezone', className: 'scheduledTimezone dt-body-center', visible: false },						{ targets: 'scheduledTimeZoneInd', data: 'scheduledTimeZoneInd', className: 'scheduledTimeZoneInd dt-body-center', visible: false },						{ 							targets: 'scheduledDuration', 										data: 'scheduledDuration', 									className: 'scheduledDuration dt-body-center',							render: function ( data, type, row, meta ) {																if ( data < 0 ) {									return '<span class="material-icons warning" title="Scheduled end time preceeds start time">warning</span>'								} else {									if ( data > 90 ) {										return `<span class="material-icons warning" title="Scheduled end time results in an unusually long duration of ${data} minutes.">warning</span>`									} else {										return data									}								}															}						},						{ 							targets: 'actualStartDateTime', 									data: 'actualStartDateTime',									className: 'dt-body-center',							render: function ( data, type, row ) {								if ( type === 'sort' ) {									return moment( data, 'MM/DD/YYYY hh:mm A z' ).format( 'YYYY/MM/DD HH:mm:ss' );								}								return data;							}						},						{ targets: 'actualStartDate', data: 'actualStartDate', className: 'dt-body-center dt-head-center',	visible: false },						{ targets: 'actualStartTime', data: 'actualStartTime', className: 'dt-body-center dt-head-center', visible: false },						{ targets: 'actualEndDateTime', data: 'actualEndDateTime', className: 'end dt-body-center dt-head-center', visible: false },						{ targets: 'actualEndTime', data: 'actualEndTime', className: 'dt-body-center dt-head-center', visible: false },						{ 							targets: 'actualDuration', 											data: 'actualDuration', 										className: 'dt-body-center dt-head-center',							render: function ( data, type, row, meta ) {																if ( data === null && row.actualStartDateTime ) {									return '<span class="material-icons warning" title="It appears that this call was not ended">warning</span>'								} else {									return data								}															}						},						{ 							targets: 'actions', 													defaultContent: '',												className: 'dt-body-center dt-head-center', 							orderable: false,							render: function ( data, type, row, meta ) {								return 	`<span class="actions" style="cursor: pointer; display: none;">`										+		`<i class="material-symbols-outlined deleteButton">delete</i>`										+		`<i class="material-symbols-outlined editButton">edit</i>`										+ `</span>`							}						}					],					order: [[ 5, 'desc' ]]				});			//-----------------------------------------------------------------------------------			//-----------------------------------------------------------------------------------			$( '#showEnds' ).click( function() {			//-----------------------------------------------------------------------------------								if ( !$( this ).parent().hasClass( 'is-checked' ) ) {					table.columns( '.end' ).visible( true );				} else {					table.columns( '.end' ).visible( false );				}							});			//-----------------------------------------------------------------------------------												//-----------------------------------------------------------------------------------			$( '#button_newCall' ).on( 'click', function() {			//-----------------------------------------------------------------------------------				$( '#newCall' )					.dialog({ title: 'New Call' })					.data( 'newCall', true ) 					.data( 'controlGroup', 'show' )					.dialog( 'open' );							});			//-----------------------------------------------------------------------------------			//-----------------------------------------------------------------------------------			$( '#scheduledStartDateTime' ).on( 'change', function() {			//-----------------------------------------------------------------------------------				adjustLocalStartDateTime();			});			//-----------------------------------------------------------------------------------			//-----------------------------------------------------------------------------------			$( '#actualStartDateTime' ).on( 'change', function() {			//-----------------------------------------------------------------------------------								if ( !!$( '#actualStartDateTime' ).val() && !!$( '#actualEndDateTime' ).val() ) {										const actualStartDateTime = moment( $( '#actualStartDateTime' ).val() );					const actualEndDateTime = moment( $( '#actualEndDateTime' ).val() );					const actualDiff = actualEndDateTime.diff( actualStartDateTime );										if ( !moment( actualEndDateTime ).isAfter( actualStartDateTime ) ) {												$( '#actualStartDateTime' ).addClass( 'ui-state-error' );						alert( 'Actual start date/time must preceed actual end date/time' );						return false 											} else {												$( '#actualStartDateTime' ).removeClass( 'ui-state-error' );											}					if ( !!actualDiff ) {						$( '#actualDuration' ).val( moment.duration( actualDiff ).as( 'minutes' ) + ' minutes' );					} else {						$( '#actualDuration' ).val( '' );					}									}				$('#actualEndDateTime').prop('min', $(this).val() );							});			//-----------------------------------------------------------------------------------			//-----------------------------------------------------------------------------------			$( '#actualEndDateTime' ).on( 'change', function() {			//-----------------------------------------------------------------------------------								if ( !!$( '#actualStartDateTime' ).val() && !!$( '#actualEndDateTime' ).val() ) {										const actualStartDateTime = moment( $( '#actualStartDateTime' ).val() );					const actualEndDateTime = moment( $( '#actualEndDateTime' ).val() );					const actualDiff = actualEndDateTime.diff( actualStartDateTime );										if ( !moment( actualEndDateTime ).isAfter( actualStartDateTime ) ) {												$( '#actualEndDateTime' ).addClass( 'ui-state-error' );						alert( 'Actual end date/time must be later than actual start date/time' );						return false 											} else {												$( '#actualEndDateTime' ).removeClass( 'ui-state-error' );											}					if ( !!actualDiff ) {						$( '#actualDuration' ).val( moment.duration( actualDiff ).as( 'minutes' ) + ' minutes' );					} else {						$( '#actualDuration' ).val( '' );					}				}				$('#actualStartDateTime').prop('max', $(this).val() );			});			//-----------------------------------------------------------------------------------					});	</script>		<style>				.is-hidden {			display: none;		}				.mdl-switch__ripple-container {			height: 24px;			width: auto;		}		table.dataTable thead th {			vertical-align: bottom;		}				table.dataTable thead th.center {			text-align: center;		}				table.dataTable tbody tr {			height: 37px;		}						.ui-selectmenu-menu {			z-index: 200;		}				.ui-checkboxradio-label {			padding-right: 75px;			width: 200px;			text-align: left;			margin-top: 1px;			margin-bottom: 1px;		}				span.warning {			color: #ff9966;		}				.controlGroup {				      border: 1px solid #ccc;	      border-radius: 10px;	      margin-top: 20px;	      padding: 15px;	      position: relative;	      width: 600; /* Adjust width as needed */			}				.controlGroupTitle {				      position: absolute;	      top: -12px;	      left: 10px;	      background-color: #fff;	      padding: 0 5px;	      font-weight: bold;		}				.dateTime {			height: 25px;			width: 190px;		}			</style></head><body><!-- Always shows a header, even in smaller screens. --><div class="mdl-layout mdl-js-layout mdl-layout--fixed-header">		<header class="mdl-layout__header">		<div class="mdl-layout__header-row">			<!-- Title -->			<span class="mdl-layout-title"><% =title %></span>				<!-- Add spacer, to align navigation to the right -->			<div class="mdl-layout-spacer"></div>						<!-- #include file="includes/mdlLayoutNavLarge.asp" -->				</div>				<!-- #include file="includes/customerTabs.asp" -->			</header>    	<div class="mdl-layout__drawer">		<span class="mdl-layout-title">Customer View</span>	</div><!-- 	<main id="mainContent" class="mdl-layout__content"> -->    	<!-- 	Snackbar -->	<div class="mdl-snackbar mdl-js-snackbar">		<div class="mdl-snackbar__text"></div>		<button type="button" class="mdl-snackbar__action"></button>	</div>			<!-- 	Call Delete Confirmation Dialog -->	<div id="confirmDelete" title="Delete the call?" style="display: none;">				<table>			<tr>				<td>					<span class="material-icons" style="font-size: 48px;">warning</span>				</td>				<td>					<span class="messageText">The call will be deleted. This action can only be undone by a system administrator.</span>				</td>			</tr>		</table>				<input type="hidden" id="deleteCallID" value=""/>	</div>	<!-- New Call Dialog -->	<div id="newCall" title="New Call" style="display: none;">		<p>			<div style="display: inline-block; margin-bottom: 10px;">				<label for="newCallType">Customer Call Type:*</label><br>				<select id="newCallType">				</select>			</div>		</p>						<div class="controlGroup scheduled">			<span class="controlGroupTitle">Scheduled</span>					<div style="display: inline-block">						<label for="scheduledStartDateTime">Start:*</label><br>						<input type="datetime-local" id="scheduledStartDateTime" class="dateTime">					</div>							<div style="display: inline-block">						<label for="newTimezone" style="height: 25px; width: 258px; padding-left: 14px">Time Zone Identifier:</label><br>						<select id="newTimezone">						</select>					</div>										<div style="display: inline-block">						<label for="newDuration">Duration:*</label><br>						<select id="newDuration">							<option value="15">&#188; hour</option>							<option value="30" selected>&#189; hour</option>							<option value="45">&#190; hour</option>							<option value="60">1 hour</option>							<option value="75">1&#188; hours</option>							<option value="90">1&#189; hours</option>							<option value="105">1&#190; hours</option>							<option value="120">2 hours</option>						</select>					</div>							<div style="margin-top: 10px;" disabled>Current User's Local Date/Time:</div>								<div style="display: inline-block">						<input type="datetime-local" id="localStartDateTime" class="dateTime" disabled>					</div>					<div style="display: inline-block">						<input id="localTimezone" type="text" style="height: 25px; width: 258px; padding-left: 14px" title="The time zone of the local browser" disabled>						</div>												</div>				<br>		<div class="controlGroup initialNotes">			<span class="controlGroupTitle">Initial Notes</span>						<p>Select which agenda items to copy into call notes:<br><i>If disabled, the agenda item(s) do not apply to the selected Customer Call Type</i></p>			<div>				<input type="checkbox" id="newCopyUtopias" disabled>				<label for="newCopyUtopias">Copy Utopias</label>			</div>			<div>				<input type="checkbox" id="newCopyKeyInitiatives" disabled>				<label for="newCopyKeyInitiatives" name="">Copy Key Initiatives</label>			</div>			<div>				<input type="checkbox" id="newCopyProjects" disabled>				<label for="newCopyProjects">Copy Projects</label>			</div>		</div>		<div class="controlGroup actual">			<span class="controlGroupTitle">Actual</span>			<div style="display: inline-block">				<label for="actualStartDateTime">Start:</label><br>				<input type="datetime-local" id="actualStartDateTime" class="dateTime">			</div>			<div style="display: inline-block">				<label for="actualTimezone">Time Zone Identifier:</label><br>				<select id="actualTimezone" style="height: 25px; width: 258px; padding-left: 14px;" disabled>				</select>			</div>						<div style="margin-top: 10px;">							<div style="display: inline-block">					<label for="actualEndDateTime">End:</label><br>					<input type="datetime-local" id="actualEndDateTime" class="dateTime">				</div>				<div style="display: inline-block">					<label for="actualDuration">Duration:</label><br>					<input id="actualDuration" type="input" style="height: 25px; width: 280px;" disabled>					</div>			</div>							</div>						<input type="hidden" id="callID">		<input type="hidden" id="customerID">					</div>					<main class="mdl-layout__content">		<div class="page-content">			<!-- Your content goes here -->				<div class="mdl-grid">				<div class="mdl-layout-spacer"></div>								<div class="mdl-cell mdl-cell--1-col" align="left">					<% if userPermitted(61) then %>						<button id="button_newCall" class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect mdl-button--accent">New Call</button>					<% end if %>				</div>					<div class="mdl-cell mdl-cell--8-col" align="left">					<label class="mdl-switch mdl-js-switch mdl-js-ripple-effect" for="showEnds">					  <input type="checkbox" id="showEnds" class="mdl-switch__input">					  <span class="mdl-switch__label">Show end date and time</span>					</label>				</div>												<div class="mdl-layout-spacer"></div>			</div>				<div class="mdl-grid">				<div class="mdl-layout-spacer"></div>				<div class="mdl-cell mdl-cell--10-col" style="text-align: center; ">							<table id="tbl_clientCalls" class="compact display">						<thead>							<tr>								<th class="callName" rowspan="2">Name</th>								<th class="callTypeID" rowspan="2">Type ID</th>								<th class="callTypeName" rowspan="2">Call Type</th>								<th class="callLeadID" rowspan="2">Lead ID</th>								<th class="callLeadName" rowspan="2">Lead Name</th>								<th class="type center" colspan="9">Scheduled</th>								<th class="type center" colspan="6" style="border-left: solid #111 1px;">Actual</th>								<th class="actions center" rowspan="2">Actions</th>							</tr>															<tr>								<th class="scheduledStartDateTime center">Start</th>								<th class="scheduledStartDate">Start Date</th>								<th class="scheduledStartTime">Start Time</th>								<th class="scheduledEndDateTime center">End</th>								<th class="scheduledEndDate">End Date</th>								<th class="scheduledEndTime">End Time</th>								<th class="scheduledTimezone center">Time Zone</th>								<th class="scheduledTimeZoneInd center">Time Zone Ind</th>								<th class="scheduledDuration center">Duration</th>								<th class="actualStartDateTime center">Start</th>								<th class="actualStartDate">Start Date</th>								<th class="actualStartTime">Start Time</th>								<th class="actualEndDateTime center">End</th>								<th class="actualEndTime">End Time</th>								<th class="actualDuration center">Duration</th>							</tr>						</thead>					</table>						</div>				<div class="mdl-layout-spacer"></div>			</div>		</div>			</main>		<!-- #include file="includes/pageFooter.asp" --></div><script src="dialog-polyfill.js"></script>  <script>		var add_callType = document.getElementById('add_callType');	if (add_callType) {		add_callType.addEventListener('change', function() {			callType_onChange(this);		});	}		// New Call Controls	var dialog_addCall = document.querySelector('#dialog_addCall');	if (dialog_addCall) {		if (! dialog_addCall.showModal) {			dialogPolyfill.registerDialog(dialog_addCall);		}		}		var button_newCall = document.querySelector('#button_newCall');			if (button_newCall) {		//-------------------------------------------------------------------------------------------// 		button_newCall.addEventListener('click', function() {// 		//-------------------------------------------------------------------------------------------// 			// 			var timeIncrement = 15;// 			var currDate 		= moment().format('YYYY-MM-DD');// 			var currDateTime 	= moment().format('YYYY-MM-DDTHH:mm');		// 			document.getElementById('add_callDate').value = currDate;// 			document.getElementById('add_callDate').parentNode.classList.add('is-dirty');// 			// 			// startTime is first 30-minute increment after current time...// 			var startTime = moment().startOf('hour').add(timeIncrement,'minutes');// 			if (startTime.isBefore(moment())) {// 				startTime.add(timeIncrement,'minutes');// 			}// 			// // 			// endTime starts out 30 minutes after the initial startTime....// // 			var endTime = moment(startTime).add(timeIncrement,'minutes');// // // 			// populate "start time" with the next 15 minute increment following current time			// 			var add_callStartTime = document.getElementById('add_callStartTime');// 			add_callStartTime.value = startTime.format('HH:mm');	// 			add_callStartTime.parentNode.classList.add('is-dirty');// // // 			// populate the endTime <select> with <option>'s for each 30-minute increment until end-of-day....// 			var add_callEndTime = document.getElementById('add_callEndTime');// // 			var enteredTime = moment(add_callStartTime.value, 'hh:mm A');// 			var arrDuration = [// 				' - &#188; hour',// 				' - &#189; hour',// 				' - &#190; hour',// 				' - 1 hour',// 				' - 1&#188; hours',// 				' - 1&#189; hours',// 				' - 1&#190; hours',// 				' - 2 hours'// 			]// 			var add_callDuration = document.getElementById('add_callDuration');// 			for (i = 0; i < add_callDuration.options.length; ++i) {// 				// 				var minutesToAdd = parseInt(add_callDuration[i].value,10);// 				add_callDuration.options[i].innerHTML = moment(enteredTime).add(minutesToAdd,'minutes').format('hh:mm A') + arrDuration[i];// 				// 				// 			}// 			// // // 			// show the populated dialog...			// 			dialog_addCall.showModal();// 			// 		});		}/*	var add_callStartTime = document.getElementById('add_callStartTime');	if (add_callStartTime) {				add_callStartTime.addEventListener('change', function() {						var enteredTime = moment(add_callStartTime.value, 'hh:mm A');			var arrDuration = [				' - &#188; hour',				' - &#189; hour',				' - &#190; hour',				' - 1 hour',				' - 1&#188; hours',				' - 1&#189; hours',				' - 1&#190; hours',				' - 2 hours'			]			var add_callDuration = document.getElementById('add_callDuration');			for (i = 0; i < add_callDuration.options.length; ++i) {								var minutesToAdd = parseInt(add_callDuration[i].value,10);				add_callDuration.options[i].innerHTML = moment(enteredTime).add(minutesToAdd,'minutes').format('hh:mm A') + arrDuration[i];											}								});	}*//*	//-------------------------------------------------------------------------------------------	dialog_addCall.querySelector('.cancel').addEventListener('click', function() {	//-------------------------------------------------------------------------------------------		dialog_addCall.close();		dialog_addCall.querySelector('#add_callType').selectedIndex = 0;		dialog_addCall.querySelector('#add_callDate').closest('div').classList.add('is-hidden');	});	//----------------------------------------