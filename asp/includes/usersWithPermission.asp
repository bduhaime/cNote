<% '!-- ------------------------------------------------------------------ -->'!-- Copyright 2017-2021, Polaris Consulting, LLC. All Rights Reserved. -->'!-- ------------------------------------------------------------------ -->' This function returns a comma-delimited string of usernames (ie, email addresses) that are associated with ' the permissionID passed as the parameter.'' two parameters are required. '' 		usersWithPermission(permissionID,format)''			permissionID ==> the permission ID to search for'			format ==> the format that results are returned in:''				"email" 	--> returns a comma-delimited string of email addresses associated with permissionID (default)'				"id" 		--> returns a comma-delimited string of user IDs associated with permissionID'function usersWithPermission(id,format)	dbug("usersWithPermission: start")		if format = "id" then 		returnFormat = "id"	else 		returnFormat = "email"	end if		if isNull(id) then 		dbug("usersWithPermission: id parameter is null")			usersWithPermission = ""			else 		 		dbug("usersWithPermission: id parameter is NOT null")		SQL = "select u.id, u.username " &_				"from cSuite..permissions p " &_				"join userPermissions up on (up.permissionID = p.id and p.id = " & id & ") " &_				"join cSuite..users u on (u.id = up.userID) " &_				"union " &_				"select u.id, u.username " &_				"from cSuite..permissions p " &_				"join rolePermissions rp on (rp.permissionID = p.id and p.id = " & id & ") " &_				"join roles r on (r.id = rp.roleID) " &_				"join userRoles ur on (ur.roleID = r.id) " &_				"join cSuite..users u on (u.id = ur.userID) "		dbug("usersWithPermission: " & SQL)		set rsUWP = dataconn.execute(SQL)				if rsUWP.eof then 						dbug("usersWithPermission: no users with this permission")			usersWithPermission = ""						else 						dbug("usersWithPermission: collecting cSuite..users with this permission...")						while not rsUWP.eof 							if len(userList) > 0 then 					if returnFormat = "email" then 						userList = userList & ", " & trim(rsUWP("username"))					else 						userList = userList & "," & rsUWP("id")					end if				else 					if returnFormat = "email" then 						userLIst = trim(rsUWP("username"))					else 						userList = rsUWP("id")					end if				end if								rsUWP.movenext 							wend 						dbug("usersWithPermission: userList = " & userList)						usersWithPermission = userList 					end if				rsUWP.close 		set rsUWP = nothing 			end if		end function%>