**/.env
**/.env.*
!**/.env.example

# Classic ASP env-specific secrets
/asp/config.json
/asp/global.asa
/asp/Global.asa
/asp/web.config
/asp/web.*.config
!/asp/web.config.template

# API env-specific secrets
/api/config/db.js

