<%'!-- ------------------------------------------------------------------ -->'!-- Copyright 2017-2021, Polaris Consulting, LLC. All Rights Reserved. -->'!-- ------------------------------------------------------------------ -->function userLog(activityDesc)	if not isObject(dataconn) then' 		dbug("dataconn is NOT an object at start of userLog(), where'd it go?!!")		if len(session("dbName")) > 0 then ' 			dbug("session has a client, so re-establishing dataconn...")			%>			<!-- #include file="../includes/dataconnection.asp" -->			<%		end if 	end if		const adCmdUnspecified 		= -1	const adExecuteNoRecords 	= 128		if len(request.querystring) > 0 then 		scriptName = request.serverVariables("SCRIPT_NAME") & "?" & request.querystring	else 		scriptName = request.serverVariables("SCRIPT_NAME")	end if		if len(session("userID")) > 0 then		userID = session("userID") 	else 		userID = "NULL"	end if		logCustomerID = "NULL"		activityDesc = replace(activityDesc, "'", "''")		' 	NOTE: id is calculated automatically by the DBMS'	NOTE: activityDateTime is automatically calculated by the DBMS		SQL = "insert into userActivity (userID, activityDescription, remoteAddr, sessionID, scriptName, customerID) " &_			"values " &_				"( " &_					userID & ", " &_					"'" & activityDesc & "', " &_					"'" & request.serverVariables("REMOTE_ADDR") & "', " &_					"'" & session.sessionID & "', " &_					"'" & scriptName & "', " &_					logCustomerID & " " &_				") "	dbug(SQL)		set rsUA = dataconn.execute(SQL, adCmdUnspecified, adExecuteNoRecords)	set rsUA = nothing		end function%>