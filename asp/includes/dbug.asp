ME") & "]: " & message)			end if			if err.number <> 0 then				response.write("err.number: " & err.number & "<br>")				response.write("err.description: " & err.description & "<br>")				response.write("attempted message: " & message & "<br>")			end if						on error goto 0			end ifend function%>