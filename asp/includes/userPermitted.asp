<% '!-- ------------------------------------------------------------------ -->'!-- Copyright 2017-2021, Polaris Consulting, LLC. All Rights Reserved. -->'!-- ------------------------------------------------------------------ -->' This function determines if the current user, as noted in session(userID), has been associated' with the permision ID passed as the parameter, id.'function userPermitted(id)	' 	dbug("userPermitted(" & id & ")")		if isNull(session("userID")) then		' keep this in sync with /includes/security.asp		response.clear()		response.redirect "/login.asp?msg=Please login" 	else							upSQL = 	"select x.permissionID " &_					"from csuite..users u " &_					"join ( " &_						"select ur.userID, rp.permissionID " &_						"from rolePermissions rp " &_						"join userRoles ur on (ur.roleID = rp.roleID) " &_						"where rp.permissionID = " & id & " " &_						"and ur.userID = " & session("userID") & " " &_						"UNION " &_						"select up.userID, up.permissionID " &_						"from userPermissions up " &_						"where up.permissionID = " & id & " " &_						"and up.userID = " & session("userID") & " " &_					") as x on (x.userID = u.id) " &_					"where u.id = " & session("userID") & " " &_					"and (u.deleted = 0 or u.deleted is null) " &_					"and u.active = 1 "		' 		dbug("userPermission SQL: " & upSQL)		set rsUserPermitted = dataconn.execute(upSQL)		if not rsUserPermitted.eof then			userPermitted = true		else			userPermitted = false		end if		rsUserPermitted.close		set rsUserPermitted = nothing	end ifend function%>