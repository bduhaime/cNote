<% '!-- ------------------------------------------------------------------ -->'!-- Copyright 2017-2021, Polaris Consulting, LLC. All Rights Reserved. -->'!-- ------------------------------------------------------------------ -->' This function determines if the user, passed as a parameter user, has been associated' with the permision ID passed as the parameter id.'' This is similar to userPermitted(), the single difference being that the userID is passed' as a parameter rather than assuming the "currently logged in user" implied by using the session variable.function userHasPermission(user,id)		if isNull(user) then		userHasPermission = false	else							uhpSQL = "SELECT * " &_					"FROM " &_					"	( " &_					"	SELECT 	rp.permissionID " &_					"	FROM 	userRoles ur, rolePermissions rp " &_					"	WHERE 	ur.userID = " & user & " " &_ 					"	AND 	ur.roleID = rp.roleID " &_					"	UNION " &_					"	SELECT 	up.permissionID " &_					"	FROM 	userPermissions up " &_					"	WHERE 	up.userID = " & user & " " &_					"	) x " &_					"WHERE permissionID = " & id & " "				dbug("userHasPermission SQL: " & uhpSQL)		set rsUHP = dataconn.execute(uhpSQL)		if not rsUHP.eof then			userHasPermission = true		else			userHasPermission = false		end if		rsUHP.close		set rsUHP = nothing	end ifend function%>