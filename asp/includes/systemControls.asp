<%'!-- ------------------------------------------------------------------ -->'!-- Copyright 2017-2021, Polaris Consulting, LLC. All Rights Reserved. -->'!-- ------------------------------------------------------------------ -->function systemControls(parm)	dbug("start systemControls(" & parm & ")")	dbug("parm=" & parm)	sctlSQL = "select [value] from systemControls where [name] = '" & parm & "' "	dbug(sctlSQL)		set rsCtl = dataconn.execute(sctlSQL)		if not rsCtl.eof then		dbug("parm found, value = '" & rsCtl("value") & "'")		systemControls = rsCtl("value")	else		dbug("systemControls error, parm='" & parm & "' not found")		systemControls = ""	end if		rsCtl.close	set rsCtl = nothingdbug("end systemControls")end function%>