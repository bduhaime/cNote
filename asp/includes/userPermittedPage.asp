<% '!-- ------------------------------------------------------------------ -->'!-- Copyright 2017-2021, Polaris Consulting, LLC. All Rights Reserved. -->'!-- ------------------------------------------------------------------ -->' This function determines if the current user, as noted in session(userID), has been associated' with the script/page passed as the parameter, pageName.'' This function requires that includes/userPermitted.asp is available, best to include userPermitted.asp' at the same level/location that userPermittedPage is included.'function userPermittedPage(pageName)		dbug("userPermittedPage called with: " & pageName)	SQL = "select ID, csuiteOnly, nonCsuiteOnly from cSuite..permissions where script_name = '" & trim(pageName) & "' " 	set rsP = dataconn.execute(SQL)	if not rsP.eof then 				dbug("page found on 'permissions' table, so determining if it is cSuite only...")		if rsP("csuiteOnly") then 						dbug("this page is only accessible when connected to cSuite client/database...") 			if lCase(session("dbName")) = "csuite" then 				userPermittedPage = true 			else 				userPermittedPage = false			end if					else 						if rsP("nonCsuiteOnly") then 								dbug("this page is only accessible connected to a a NON cSuite client/database...")				if lCase(session("dbName")) <> "csuite" then 					if userPermitted(rsP("id")) then 						userPermittedPage = true 					else 						userPermittedPage = false					end if 				else 					userPermittedPage = false				end if							else 											dbug("this page is accessible for all clients/databases...")				dbug("page found on 'permissions' table, so calling userPermitted with id: " & rsP("id"))								permissionID = rsP("id")				if userPermitted(permissionID) then 					dbug("userPermitted() = TRUE")					userPermittedPage = true 				else 					dbug("userPermitted() = FALSE")					userPermittedPage = false				end if							end if				end if 			else 				dbug("page NOT found on 'permissions' table, so access denied.")				userPermittedPage = false		end if 		rsP.close 	set rsp = nothing 	end function%>